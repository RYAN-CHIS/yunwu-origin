# 允物独立站 — 环境变量

# PostgreSQL 连接（生产环境）
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ERP 数据库（P0-6B: 商品价格/库存读取来源）
# 当 Product.erp_product_id 有值时，优先从 ERP 读取 price & finishedStock
# 未设置时，商品价格/库存使用 Web DB 的 salePrice & stock
ERP_DATABASE_URL="postgresql://user:password@host:5432/erp_database?sslmode=require"

# 网站配置
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="允物 Yunwu Origin"

# 联系方式（公开，NEXT_PUBLIC_ 前缀）
NEXT_PUBLIC_WECHAT="yunwu2024"
NEXT_PUBLIC_EMAIL="hello@yunwuorigin.com"
NEXT_PUBLIC_XIAOHONGSHU="https://www.xiaohongshu.com/user/允物"

# Product OS 临时迁移开关：迁移验证完成并移除旧 status fallback 后删除
# true（默认）使用 publish_status；false 临时回退旧 status
PRODUCT_OS_USE_PUBLISH_STATUS="true"
