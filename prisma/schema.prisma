generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// 权限系统
// ═══════════════════════════════════════════════════════

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  OPERATOR
}

// ═══════════════════════════════════════════════════════
// 七序体系
// ═══════════════════════════════════════════════════════

model Series {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String
  shortDesc   String?   @map("short_desc")
  longDesc    String?   @db.Text @map("long_desc")
  coverImage  String    @default("")
  heroText    String    @default("")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("series")
}

// ═══════════════════════════════════════════════════════
// 器物体系
// ═══════════════════════════════════════════════════════

enum ObjectCategory {
  BRACELET
  INCENSE
  SEAL
  CERAMIC
  ENAMEL
  SCHOLAR
}

// ═══════════════════════════════════════════════════════
// 作品中心
// ═══════════════════════════════════════════════════════

model Product {
  id                Int               @id @default(autoincrement())
  sku               String            @unique
  name              String
  slug              String            @unique
  seriesId          Int               @map("series_id")
  object_category   ObjectCategory    @default(BRACELET)
  theme             String            @default("")
  story             String            @default("")
  inspiration       String?
  materials         String            @default("")
  suitableFor       String?           @map("suitable_for")
  lifeStage         String?           @map("life_stage")
  keywords          String?
  costPrice         Float             @default(0) @map("cost_price")
  salePrice         Float             @default(0) @map("sale_price")
  coverImage        String            @default("") @map("cover_image")
  gallery           String            @default("[]")
  stock             Int               @default(0)
  status            String            @default("draft")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  materialsRelation ProductMaterial[]
  productTags       ProductTag[]
  series            Series            @relation(fields: [seriesId], references: [id])

  @@index([seriesId])
  @@index([status])
  @@index([object_category])
  @@map("products")
}

// ═══════════════════════════════════════════════════════
// 材料研究库
// ═══════════════════════════════════════════════════════

model Material {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  alias            String?
  type             String            @default("")
  origin           String            @default("")
  history          String?           @db.Text
  features         String?           @db.Text
  description      String            @default("")
  image            String            @default("")
  relatedArticles  String            @default("[]") @map("related_articles")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  productMaterials ProductMaterial[]

  @@map("materials")
}

// ═══════════════════════════════════════════════════════
// 作品-材料多对多
// ═══════════════════════════════════════════════════════

model ProductMaterial {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  materialId Int      @map("material_id")
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId])
  @@map("product_materials")
}

// ═══════════════════════════════════════════════════════
// 品牌志
// ═══════════════════════════════════════════════════════

enum JournalCategory {
  OBJECT
  MATERIAL
  CRAFT
  DONGHAI
  CREATION
  PHILOSOPHY
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

model JournalPost {
  id             String          @id @default(cuid())
  title          String
  slug           String          @unique
  excerpt        String?
  content        String
  coverImage     String?         @map("cover_image")
  coverAlt       String?         @map("cover_alt")
  readingTime    Int?            @map("reading_time")
  category       JournalCategory
  status         PublishStatus   @default(DRAFT)
  seoTitle       String?         @map("seo_title")
  seoDescription String?         @map("seo_description")
  publishedAt    DateTime?       @map("published_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  journalTags    JournalTag[]

  @@index([status, publishedAt])
  @@index([category])
  @@map("journal_posts")
}

// ═══════════════════════════════════════════════════════
// 联系表单线索
// ═══════════════════════════════════════════════════════

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  wechat    String?
  email     String?
  message   String?
  sourcePage         String?  @map("source_page")
  interestedSeries   String?  @map("interested_series")
  interestedCategory String?  @map("interested_category")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("contact_leads")
}

// ═══════════════════════════════════════════════════════
// 订单
// ═══════════════════════════════════════════════════════

model Order {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique @map("order_no")
  productId    Int      @map("product_id")
  productName  String   @default("") @map("product_name")
  quantity     Int      @default(1)
  amount       Float
  customerName String   @default("") @map("customer_name")
  phone        String   @default("")
  address      String   @default("")
  remark       String   @default("")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("orders")
}

// ═══════════════════════════════════════════════════════
// 图片资产库
// ═══════════════════════════════════════════════════════

enum MediaCategory {
  PRODUCT
  BEADS
  SEAL
  INCENSE
  PORCELAIN
  WOODWORK
  OTHER_OBJ
  MATERIAL
  BRAND
  CRAFT
  ARTICLE
}

model Media {
  id       String      @id @default(cuid())
  filename String
  url      String
  category MediaCategory
  altText  String?     @map("alt_text")
  size     Int
  mimeType String      @map("mime_type")
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("media")
}

// ═══════════════════════════════════════════════════════
// SEO 中心
// ═══════════════════════════════════════════════════════

model SeoConfig {
  id          String   @id @default(cuid())
  pageKey     String   @unique @map("page_key")
  title       String
  description String
  ogImage     String?  @map("og_image")
  canonical   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("seo_configs")
}

// ═══════════════════════════════════════════════════════
// 系统设置
// ═══════════════════════════════════════════════════════

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ═══════════════════════════════════════════════════════
// 审计日志
// ═══════════════════════════════════════════════════════

model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════
// 页面内容管理（第二模块）
// ═══════════════════════════════════════════════════════

model PageContent {
  id          String   @id @default(cuid())
  pageKey     String   @map("page_key")
  sectionKey  String   @map("section_key")
  title       String   @default("")
  content     String   @default("") @db.Text
  image       String?
  sortOrder   Int      @default(0) @map("sort_order")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([pageKey, sectionKey])
  @@map("page_contents")
}

// ═══════════════════════════════════════════════════════
// 标签系统（第三模块）
// ═══════════════════════════════════════════════════════

enum TagType {
  SERIES
  VALUE
  MATERIAL
  EMOTION
  SCENE
  OBJECT
}

model Tag {
  id           String        @id @default(cuid())
  name         String        @unique
  slug         String        @unique
  description  String?
  type         TagType
  productTags  ProductTag[]
  journalTags  JournalTag[]
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("tags")
}

model ProductTag {
  id        String   @id @default(cuid())
  productId Int      @map("product_id")
  tagId     String   @map("tag_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@map("product_tags")
}

model JournalTag {
  id          String       @id @default(cuid())
  journalId   String       @map("journal_id")
  tagId       String       @map("tag_id")
  journalPost JournalPost  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  tag         Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([journalId, tagId])
  @@map("journal_tags")
}
